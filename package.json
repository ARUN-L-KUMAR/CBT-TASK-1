{
  "name": "chennai-artisanal-goods-provenance",
  "version": "1.0.0",
  "description": "A DApp for tracking provenance of artisanal goods from Chennai",
  "scripts": {
    "compile": "truffle compile",
    "migrate": "truffle migrate",
    "test": "truffle test",
    "copy-abi": "node scripts/copyAbi.js",
    "deploy": "truffle migrate --reset && npm run copy-abi",
    "client": "cd client && npm start",
    "client-install": "cd client && npm install"
  },
  "dependencies": {
    "@truffle/hdwallet-provider": "^1.7.0",
    "dotenv": "^16.5.0"
  }
}
